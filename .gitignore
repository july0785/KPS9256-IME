# ── 빌드 산출물 ───────────────────────────────────────────
/build/
*.obj
*.res
*.exp
*.lib
*.pdb
*.ipdb
*.iobj
*.ilk

# 설치기(KPS9256-setup.exe)는 일부러 저장소에 함께 올린다 — 받는 사람이 바로 받게.
#   (DLL 내장·정적 CRT 라 빌드/런타임 없이 실행됨)
/test/*.exe

# 잠겨 있던 DLL 을 옆으로 치운 사본
*_old_*.dll

# ── Visual Studio 부스러기 ────────────────────────────────
.vs/
*.user
*.aps
*.suo

# ── 미리보기 이미지 ───────────────────────────────────────
/jo_*.png

# 참고: jo.ico, *.rc, *.manifest, *.def, *.vcxproj, *.sln, *.bat,
#       *.ps1, 소스(.h/.cpp) 는 모두 커밋한다.

# 내부 작업지령서는 _local/ 에 보관(로컬 전용, 공개 안 함)
/_local/
